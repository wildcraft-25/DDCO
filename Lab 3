Structural model

module structural(a,b,y); 
input a,b; 
output y;
or g1(y,a,b); 
endmodule


Dataflow model

module dataflow(a,b,y); 
input a,b; 
output y;
assign y=a|b;
endmodule


Behavioural model

module beh(a,b,y);
input a,b; 
output y; 
reg y;
always @(a or b)
begin
if((a==0)&&(b==0)) 
y=0;
endmodule end
else
y=1;
